{
  "rules": {

    "users": {
      ".read": true,
      ".write": "auth != null"
    },

    "sensor-readings": {
      ".read": true,
      "$siteId": {
        ".write": true,
        "gateways": {
          "$gatewayId": {
            "$nodeId": {
              ".indexOn": [".priority"]
            }
          }
        }
      }
    },

    "serviceData": {
      "sites": {
        ".read": "auth != null",
        ".write": "auth != null && (
          root.child('users').child(auth.uid).child('role').val() === 'admin' ||
          root.child('users').child(auth.uid).child('role').val() === 'technician'
        )"
      },
      "sensors": {
        ".read": "auth != null",
        "$nodeId": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'technician' || (root.child('users').child(auth.uid).child('role').val() === 'customer' && root.child('users').child(auth.uid).child('siteId').val() === newData.child('siteId').val()))"
        }
      },
      "serviceEvents": {
        ".read": "auth != null && (
          root.child('users').child(auth.uid).child('role').val() === 'admin' ||
          root.child('users').child(auth.uid).child('role').val() === 'technician'
        )",
        "$eventId": {
          ".write": "auth != null && !data.exists() && (
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'technician'
          )"
        }
      },
    	"zones": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$zoneId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    }

  }
}